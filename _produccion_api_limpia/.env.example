PORT=3001

# Variables locales usadas por el API.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=flujo_gastos

# Variables compatibles con Railway PostgreSQL.
# En Railway normalmente se llenan con referencias al servicio Postgres:
# PGDATABASE="${{Postgres.PGDATABASE}}"
# PGHOST="${{Postgres.PGHOST}}"
# PGPASSWORD="${{Postgres.PGPASSWORD}}"
# PGPORT="${{Postgres.PGPORT}}"
# POSTGRES_USER="${{Postgres.POSTGRES_USER}}"
# POSTGRES_PASSWORD="${{Postgres.POSTGRES_PASSWORD}}"
PGDATABASE=
PGHOST=
PGPASSWORD=
PGPORT=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Opcional: si usas una URL completa de PostgreSQL, tiene prioridad en TypeORM.
DATABASE_URL=

# Origenes permitidos para CORS, separados por coma.
CORS_ORIGINS=http://localhost:4200,https://flujogastosapp-production.up.railway.app

# Headers permitidos por CORS, separados por coma.
CORS_ALLOWED_HEADERS=Content-Type,Authorization,x-user-id

# Opcional: activa SSL cuando el proveedor lo requiera.
# DB_SSL=true
# PGSSLMODE=require
