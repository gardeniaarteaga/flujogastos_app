{
  "name": "flujo-gastos",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prebuild": "node scripts/generate-env.js",
    "start": "ng serve",
    "start:pago-rapido-android": "ng serve pago-rapido-android --host 0.0.0.0 --port 4300",
    "build": "ng build",
    "build:pago-rapido-android": "node scripts/generate-env.js && ng build pago-rapido-android --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.7",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.24",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
