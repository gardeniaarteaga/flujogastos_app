FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG MOBILE_API_BASE_URL=https://flujogastosapi-production.up.railway.app/api
ENV MOBILE_API_BASE_URL=$MOBILE_API_BASE_URL

RUN node scripts/generate-env.js && npx ng build pago-rapido-android --configuration production

FROM caddy:2-alpine

COPY Caddyfile.pago-rapido-android /etc/caddy/Caddyfile
COPY --from=build /app/dist/pago-rapido-android/browser /srv

EXPOSE 8080
